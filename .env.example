# ============================================================
# Audio Overview Studio — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------------------------------
# TTS Provider (optional — can also be set in the TTS Setup UI)
# Options: openai | elevenlabs | kokoro | luxtts
# ------------------------------------------------------------
# AOS_TTS_PROVIDER=openai

# ------------------------------------------------------------
# OpenAI (TTS + LLM)
# Required for: OpenAI TTS voices, GPT-4o script generation
# Get your key: https://platform.openai.com/api-keys
# ------------------------------------------------------------
OPENAI_API_KEY=

# ------------------------------------------------------------
# ElevenLabs (TTS — optional)
# Required for: ElevenLabs high-quality podcast voices
# Free tier: 10,000 characters/month
# Get your key: https://elevenlabs.io → Profile → API Keys
# ------------------------------------------------------------
ELEVENLABS_API_KEY=

# ------------------------------------------------------------
# Gemini (LLM — optional)
# Required for: Gemini script generation, AI Council mode
# Get your key: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# Grok / xAI (LLM — optional)
# Required for: Grok script generation, AI Council mode
# Get your key: https://console.x.ai
# ------------------------------------------------------------
XAI_API_KEY=

# ------------------------------------------------------------
# Ollama (local LLM — optional)
# Required for: fully offline script generation
# Install Ollama: https://ollama.com  then: ollama pull llama3.2
# ------------------------------------------------------------
AOS_OLLAMA_HOST=http://localhost:11434
AOS_OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------
# Cloud model overrides (optional)
# ------------------------------------------------------------
AOS_GEMINI_MODEL=gemini-2.5-flash
AOS_OPENAI_MODEL=gpt-4o
AOS_GROK_MODEL=grok-3

# ------------------------------------------------------------
# LuxTTS (advanced voice cloning — optional)
# Only needed if you want to use LuxTTS provider.
# Point this at your cloned temp_luxtts directory.
# Also install: pip install torch torchaudio
# ------------------------------------------------------------
# AOS_LUXTTS_PATH=/path/to/temp_luxtts

# ------------------------------------------------------------
# Storage (optional — defaults to system temp directory)
# ------------------------------------------------------------
# AOS_UPLOAD_DIR=
